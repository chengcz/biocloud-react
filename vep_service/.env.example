# Service
SERVICE_NAME=VEP Annotation Service
SERVICE_VERSION=1.0.0
DEBUG=true

# Server
HOST=127.0.0.1
PORT=8001

# Database (default: PostgreSQL on port 5433 from Docker Compose)
DATABASE_URL=postgresql+asyncpg://vep_user:vep_password@localhost:5433/vep_cache

# VEP Configuration
VEP_DATA_DIR=/data/vep_data
SPECIES_CONFIG_PATH=species.yaml
VEP_TIMEOUT=300
MAX_VCF_SIZE=52428800
VEP_CACHE_RESULTS=true

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600

# CORS
CORS_ORIGINS=["*"]
